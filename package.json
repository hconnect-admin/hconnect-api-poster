{
  "name": "hconnect-api-poster",
  "version": "1.0.3",
  "description": "API test client for hconnect / Oracle Hospitality REST APIs",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build": "electron-builder --win",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "appId": "com.hconnect.api-poster",
    "productName": "hconnect API Client",
    "publish": [
      {
        "provider": "github",
        "owner": "hconnect-admin",
        "repo": "hconnect-api-poster",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "hconnect API Client"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!.github/**",
      "!*.bat",
      "!*.md",
      "!.gitignore"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "assets/**/*"
    ]
  },
  "keywords": [
    "ohip",
    "api-client",
    "oracle-hospitality"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "electron-updater": "^6.3.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0",
    "nodemon": "^3.0.0"
  }
}

